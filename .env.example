# =========================================================================
# OpenCode AI Reviewer — Local Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials.
# =========================================================================

# -------------------------------------------------------------------------
# 1. GitHub Integration & Authentication
# -------------------------------------------------------------------------

# GitHub Personal Access Token (PAT) or installation token. Required.
GITHUB_TOKEN=your_github_token_here

# For GitHub App (Probot) Setup (Only needed if running the App)
# App ID from developer settings
APP_ID=
# Absolute path to your app's private key file (.pem) or private key string
PRIVATE_KEY_PATH=
# Private key content directly as a single line (with \n)
PRIVATE_KEY=
# Webhook secret to verify payloads
WEBHOOK_SECRET=

# -------------------------------------------------------------------------
# 2. AI Model Provider Keys
# -------------------------------------------------------------------------

# (Optional) OpenCode uses these keys if configuring models from other providers.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# -------------------------------------------------------------------------
# 3. Agent Configuration Overrides
# -------------------------------------------------------------------------

# Models to use (Defaults to opencode/deepseek-v4-flash-free)
REVIEW_MODEL=opencode/deepseek-v4-flash-free
FIX_MODEL=opencode/deepseek-v4-flash-free

# Max number of files to process per sub-agent prompt batch
BATCH_SIZE=3

# Max review-fix iterations before giving up
MAX_ITERATIONS=3

# Enable/disable Model Context Protocol (MCP) servers
ENABLE_MCP=true

# -------------------------------------------------------------------------
# 4. Project Rules & Verification Settings
# -------------------------------------------------------------------------

# Path to the rules/conventions markdown document
CONVENTIONS_PATH=.agents/AGENTS.md

# Short description of your project context
PROJECT_DESCRIPTION="AI-powered PR review, auto-fix, and codebase audit system."

# Commands to run in the auto-fix loop for checking/compiling changes
# Comma-separated command strings.
TYPECHECK_COMMANDS="pnpm typecheck"
LINT_COMMANDS="pnpm lint"

# -------------------------------------------------------------------------
# 5. Local Server Settings
# -------------------------------------------------------------------------

# Probot App port (defaults to 3000)
PORT=3000

# Logging verbosity (info, debug, warn, error)
LOG_LEVEL=info
